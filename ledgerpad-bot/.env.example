# X (Twitter) API credentials — get these from developer.twitter.com
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_SECRET=your_access_token_secret_here
X_BEARER_TOKEN=your_bearer_token_here

# Optional: CryptoPanic API key for news (free at cryptopanic.com)
CRYPTOPANIC_API_KEY=your_cryptopanic_key_here

# Optional: disable live posting for local testing (set to "true" to dry-run)
DRY_RUN=false

# Timezone for tweet scheduling (default UTC)
TZ=UTC
