# Get a free key at https://dev.helius.xyz/dashboard/app
HELIUS_KEY=your_helius_api_key_here

# HTTP port for /launches.json endpoint
PORT=3000

# CORS origin for GitHub Pages (set to your GH Pages URL)
# e.g. https://yourname.github.io
CORS_ORIGIN=*

# Daily Helius credit budget (free tier = 1M/month ≈ 33k/day)
HELIUS_DAILY_BUDGET=28000

# Max forensics queue depth (prevents runaway processing on burst days)
FORENSICS_QUEUE_MAX=500
