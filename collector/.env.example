# Optional: Helius key for higher rate limits (helius.dev — free tier available)
# Without it, the collector uses Ankr's free public Solana RPC automatically.
# HELIUS_KEY=your_key_here

# Optional: override the RPC endpoint entirely
# RPC_URL=https://rpc.ankr.com/solana

# HTTP port for /launches.json endpoint
PORT=3000

# CORS origin (set to your GitHub Pages URL if hosting HTML there)
CORS_ORIGIN=*

# Daily RPC call budget
HELIUS_DAILY_BUDGET=28000
