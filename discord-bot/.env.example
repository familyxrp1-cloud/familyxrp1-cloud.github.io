# XRPL token config
TOKEN_ISSUER=rDTHkzTq3Acxu6QrSLVfHrR3KadFknMkfS
TOKEN_CURRENCY=CFH

# Whale holding threshold (in tokens)
WHALE_THRESHOLD=1000000

# Buy tier thresholds (in XRP)
