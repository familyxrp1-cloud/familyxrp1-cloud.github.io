# Discord bot token (Developer Portal > Bot > Token)
DISCORD_TOKEN=your_bot_token_here

# Name of the channel to post alerts in (no # needed)
DISCORD_CHANNEL_NAME=cfh-alerts

# xrpl.to API key
XRPLTO_API_KEY=your_xrplto_api_key_here

# XRPL token config
TOKEN_ISSUER=rDTHkzTq3Acxu6QrSLVfHrR3KadFknMkfS
TOKEN_CURRENCY=CFH

# Whale holding threshold (in tokens)
WHALE_THRESHOLD=1000000

# Buy tier thresholds (in XRP)
TIER_STRONG=50
TIER_MEGA=200
TIER_WHALE=500

# XRPL websocket node
XRPL_WS=wss://xrplcluster.com
