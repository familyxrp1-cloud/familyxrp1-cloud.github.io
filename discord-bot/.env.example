# Discord bot token (from Developer Portal > Bot > Token)
DISCORD_TOKEN=your_bot_token_here

# xrpl.to API key (speeds up whale balance lookups)
XRPLTO_API_KEY=your_xrplto_api_key_here

# ID of the Discord channel to post alerts in
# Right-click a channel in Discord > Copy Channel ID (needs Developer Mode on)
DISCORD_CHANNEL_ID=your_channel_id_here

# XRPL token config
TOKEN_ISSUER=rDTHkzTq3Acxu6QrSLVfHrR3KadFknMkfS
TOKEN_CURRENCY=CFH

# Whale holding threshold (in tokens)
WHALE_THRESHOLD=1000000

# Buy tier thresholds (in XRP)
TIER_STRONG=50
TIER_MEGA=200
TIER_WHALE=500

# XRPL websocket node
XRPL_WS=wss://xrplcluster.com
